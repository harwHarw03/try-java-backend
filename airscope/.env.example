# =============================================
# AirScope Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# --- PostgreSQL Database ---
POSTGRES_URL=jdbc:postgresql://localhost:5432/airscope
POSTGRES_USER=airscope_user
POSTGRES_PASSWORD=your_secure_password_here

# --- JWT Settings ---
# IMPORTANT: Generate a strong secret key (min 256 bits / 32 characters)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_key_min_32_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- AWS DynamoDB ---
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
DYNAMODB_LOCAL=true
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000
